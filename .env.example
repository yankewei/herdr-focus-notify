# Optional maintainer overrides. Users should not need this file. The parser
# supports KEY=value, export KEY=value, quoted values, and unquoted inline
# comments.

# Disable notifications without unlinking the plugin.
# HERDR_FOCUS_NOTIFY_ENABLED=0

# Defaults to blocked,done.
# HERDR_FOCUS_NOTIFY_STATUSES=blocked,done

# Print diagnostic output to Herdr plugin logs and focus-click.log.
# HERDR_FOCUS_NOTIFY_DEBUG=1

# Override the notify backend. Defaults to auto-detected alerter.
# HERDR_FOCUS_NOTIFY_NOTIFIER=/opt/homebrew/bin/alerter

# Open this app before focusing the Herdr pane. Use an app name or an absolute
# .app path (paths are not shell-expanded, so ~ is treated literally).
# HERDR_FOCUS_NOTIFY_ACTIVATE_APP=kitty
# HERDR_FOCUS_NOTIFY_ACTIVATE_APP=/Applications/kitty.app

# Seconds before an unclicked alert auto-dismisses (alerter only).
# 0 keeps it until dismissed. Default 3600.
# HERDR_FOCUS_NOTIFY_TIMEOUT=3600
