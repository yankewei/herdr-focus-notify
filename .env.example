# Optional maintainer overrides. Users should not need this file.

# Disable notifications without unlinking the plugin.
# HERDR_FOCUS_NOTIFY_ENABLED=0

# Defaults to blocked,done.
# HERDR_FOCUS_NOTIFY_STATUSES=blocked,done

# Print diagnostic output to Herdr plugin logs and focus-click.log.
# HERDR_FOCUS_NOTIFY_DEBUG=1

# Override the notify backend. Defaults to alerter (reliable click), falls back
# to terminal-notifier (deprecated click). 
# HERDR_FOCUS_NOTIFY_NOTIFIER=/opt/homebrew/bin/alerter

# Seconds before an unclicked alert auto-dismisses (alerter only).
# 0 keeps it until dismissed. Default 3600.
# HERDR_FOCUS_NOTIFY_TIMEOUT=3600
